<Window x:Class="MouseGestures.UI.GestureSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mouse Gesture Settings"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#F0F0F0"
        Opacity="{Binding WindowOpacity}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="Window" x:Key="TransparentWindowStyle">
            <Setter Property="WindowStyle" Value="None" />
            <Setter Property="AllowsTransparency" Value="True" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#2C2C2C" />
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#7B68AB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9080BB" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#DC3545" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C82333" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RecordButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Content" Value="🖱️ Record Gesture" />
            <Setter Property="Background" Value="#7B68AB" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecordingGesture}" Value="True">
                    <Setter Property="Content" Value="⏺️ Recording... (Click to Cancel)" />
                    <Setter Property="Background" Value="#DC3545" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9080BB" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRecordingGesture}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#C82333" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for TextBox with error state -->
        <Style x:Key="PatternTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#F9F9F9" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasDuplicatePattern}" Value="True">
                    <Setter Property="BorderBrush" Value="#DC3545" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Mouse Gesture Configuration"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#7B68AB"
                   Margin="0,0,0,20" />

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Gesture List -->
            <GroupBox Grid.Column="0" Header="Defined Gestures"
                      Padding="10"
                      BorderBrush="#7B68AB"
                      BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Gesture List -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Gestures}"
                             SelectedItem="{Binding SelectedGesture}"
                             Background="White"
                             BorderBrush="#DDDDDD">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock FontWeight="Bold" FontSize="14">
                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding PatternDescription}"
                                               Foreground="#666666"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding VsCommandName}"
                                               Foreground="#7B68AB"
                                               FontSize="11"
                                               FontStyle="Italic" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button Content="➕ Add"
                                Command="{Binding AddGestureCommand}"
                                Style="{StaticResource ModernButtonStyle}" />
                        <Button Content="✏️ Edit"
                                Command="{Binding EditGestureCommand}"
                                Style="{StaticResource ModernButtonStyle}" />
                        <Button Content="🗑️ Delete"
                                Command="{Binding DeleteGestureCommand}"
                                Style="{StaticResource DangerButtonStyle}" />
                        <Button Content="⏯️ Toggle"
                                Command="{Binding ToggleEnabledCommand}"
                                Style="{StaticResource ModernButtonStyle}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Right Panel - Details & Settings -->
            <TabControl Grid.Column="2" BorderBrush="#7B68AB">
                <!-- Gesture Details Tab -->
                <TabItem Header="Gesture Details">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10"
                                    IsEnabled="{Binding IsGestureSelected}">

                            <TextBlock Text="Gesture Properties"
                                       Style="{StaticResource SectionHeaderStyle}" />

                            <!-- Name -->
                            <TextBlock Text="Name:" FontWeight="SemiBold" Margin="0,10,0,5" />
                            <TextBox Text="{Binding SelectedGesture.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     BorderBrush="#CCCCCC" />

                            <!-- Pattern -->
                            <TextBlock Text="Pattern:" FontWeight="SemiBold" Margin="0,15,0,5" />
                            <TextBlock Text="Click 'Record Gesture' to define a new pattern"
                                       Foreground="#666666"
                                       FontSize="11"
                                       Margin="0,0,0,5" />
                            <TextBox Text="{Binding SelectedGesture.PatternDescription, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource PatternTextBoxStyle}" />

                            <!-- Duplicate Pattern Warning -->
                            <TextBlock Text="{Binding DuplicatePatternMessage}"
                                       Foreground="#DC3545"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,5,0,0"
                                       Visibility="{Binding HasDuplicatePattern, Converter={StaticResource BoolToVis}}" />

                            <Button Command="{Binding RecordGestureCommand}"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource RecordButtonStyle}" />

                            <!-- Recording hint -->
                            <TextBlock Foreground="#DC3545"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Margin="0,5,0,0"
                                       Visibility="{Binding IsRecordingGesture, Converter={StaticResource BoolToVis}}">
                                <Run Text="Press ESC or click the button to cancel recording" />
                            </TextBlock>

                            <!-- VS Command -->
                            <TextBlock Text="Visual Studio Command:"
                                       FontWeight="SemiBold"
                                       Margin="0,15,0,5" />
                            <TextBlock Text="Start typing to search..."
                                       Foreground="#666666"
                                       FontSize="11"
                                       Margin="0,0,0,5" />
                            <ComboBox x:Name="CommandComboBox"
                                      ItemsSource="{Binding FilteredCommands}"
                                      SelectedValuePath="CommandId"
                                      DisplayMemberPath="DisplayName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      StaysOpenOnEdit="True"
                                      Padding="8"
                                      BorderBrush="#CCCCCC"
                                      TextBoxBase.TextChanged="CommandComboBox_TextChanged"
                                      SelectionChanged="CommandComboBox_SelectionChanged"
                                      GotFocus="CommandComboBox_GotFocus"
                                      LostFocus="CommandComboBox_LostFocus" />

                            <!-- Enabled Status -->
                            <CheckBox Content="Enabled"
                                      IsChecked="{Binding SelectedGesture.IsEnabled}"
                                      Margin="0,15,0,0"
                                      FontWeight="SemiBold" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Visualization Settings Tab -->
                <TabItem Header="Visualization">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Visualization Settings"
                                       Style="{StaticResource SectionHeaderStyle}" />

                            <!-- Show Trail -->
                            <CheckBox Content="Show Gesture Trail"
                                      IsChecked="{Binding VisualizationSettings.ShowTrail}"
                                      Margin="0,10,0,0"
                                      FontWeight="SemiBold" />

                            <!-- Trail Color -->
                            <TextBlock Text="Trail Color:"
                                       FontWeight="SemiBold"
                                       Margin="0,15,0,5" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding VisualizationSettings.TrailColor, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100"
                                         Padding="8"
                                         BorderBrush="#CCCCCC" />
                                <TextBlock Text="  Example: #7B68AB"
                                           Foreground="#666666"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </StackPanel>

                            <!-- Trail Thickness -->
                            <TextBlock Text="Trail Thickness:"
                                       FontWeight="SemiBold"
                                       Margin="0,15,0,5" />
                            <StackPanel Orientation="Horizontal">
                                <Slider Value="{Binding VisualizationSettings.TrailThickness}"
                                        Minimum="1"
                                        Maximum="10"
                                        Width="200"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding VisualizationSettings.TrailThickness, StringFormat={}{0:F0} px}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Show Directions -->
                            <CheckBox Content="Show Direction Indicators"
                                      IsChecked="{Binding VisualizationSettings.ShowDirections}"
                                      Margin="0,20,0,0"
                                      FontWeight="SemiBold" />

                            <!-- Minimum Distance -->
                            <TextBlock Text="Minimum Gesture Distance:"
                                       FontWeight="SemiBold"
                                       Margin="0,15,0,5" />
                            <StackPanel Orientation="Horizontal">
                                <Slider Value="{Binding VisualizationSettings.MinimumGestureDistance}"
                                        Minimum="5"
                                        Maximum="50"
                                        Width="200"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding VisualizationSettings.MinimumGestureDistance, StringFormat={}{0:F0} px}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Lower values = more sensitive gesture detection"
                                       Foreground="#666666"
                                       FontSize="11"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Help Tab -->
                <TabItem Header="Help">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="How to Use Mouse Gestures"
                                       Style="{StaticResource SectionHeaderStyle}" />

                            <TextBlock TextWrapping="Wrap" Margin="0,5,0,10">
                                <Run Text="1. " FontWeight="Bold" />
                                <Run Text="Hold the right mouse button" />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="2. " FontWeight="Bold" />
                                <Run Text="Move the mouse to draw a pattern (e.g., ← for Navigate Backward)" />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="3. " FontWeight="Bold" />
                                <Run Text="Release the right mouse button to execute the command" />
                            </TextBlock>

                            <TextBlock Text="Recording Gestures"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0,20,0,0" />

                            <TextBlock TextWrapping="Wrap" Margin="0,5,0,10">
                                <Run Text="• " FontWeight="Bold" />
                                <Run Text="Click 'Record Gesture' button" />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="• " FontWeight="Bold" />
                                <Run Text="Draw your gesture with right mouse button" />
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="• " FontWeight="Bold" />
                                <Run Text="Press ESC or click the button again to cancel" />
                            </TextBlock>

                            <TextBlock Text="Available Directions"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0,20,0,0" />

                            <TextBlock TextWrapping="Wrap" Margin="0,5,0,0">
                                <Run Text="↑ Up  |  ↓ Down  |  ← Left  |  → Right" FontSize="16" />
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- About Tab -->
                <TabItem Header="About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">

                            <!-- Logo + Title in one line -->
                            <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,10">
                                <!-- Logo - Arrow only -->
                                <Viewbox Width="60" Height="60" Margin="0,0,15,0">
                                    <Canvas Width="100" Height="100">
                                        <!-- Gesture Trail (Arrow Path) -->
                                        <Path Stroke="#7B68AB" StrokeThickness="8" StrokeLineJoin="Round">
                                            <Path.Data>
                                                <PathGeometry>
                                                    <PathFigure StartPoint="20,50">
                                                        <PolyLineSegment Points="20,20 50,20 50,80 80,80" />
                                                        <PolyLineSegment Points="20,20 50,20 50,80 80,80" />
                                                    </PathFigure>
                                                </PathGeometry>
                                            </Path.Data>
                                        </Path>
                                    </Canvas>
                                </Viewbox>

                                <!-- Application Name -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Mouse Gestures"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#7B68AB"
                                       Margin="0" />

                                    <TextBlock Text="for Visual Studio"
                                       FontSize="16"
                                       Foreground="#666666"
                                       Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock FontSize="18"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20">
                                    <Run Text="&lt;" FontWeight="SemiBold" />
                                    <Run Text="_" FontWeight="SemiBold" Foreground="Red" />
                                    <Run Text="Peter />" FontWeight="SemiBold" />
                            </TextBlock>

                            <!-- Contact & License -->
                            <Border Background="#F0F0F0"
                                    CornerRadius="5"
                                    Padding="15"
                                    Margin="0,0,0,20">
                                <StackPanel>
                                    <!-- Main Description -->
                                    <TextBlock Text="Boost your productivity with intuitive mouse gestures"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#2C2C2C"
                                       Margin="0,0,0,12" />

                                    <!-- Detailed Description -->
                                    <TextBlock TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="#666666"
                                               FontSize="12"
                                               LineHeight="18">
                                        <Run Text="Execute Visual Studio commands instantly by drawing simple patterns with your mouse. " />
                                        <Run Text="No need to memorize complex keyboard shortcuts or navigate through menus. " />
                                        <Run Text="Simply hold the right mouse button, draw a gesture, and watch your commands execute seamlessly." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Author & Copyright -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Run Text="Version " Foreground="#666666" />
                                    <Run Text="{Binding AppVersion, Mode=OneWay}" FontWeight="SemiBold" Foreground="#7B68AB" />
                                </TextBlock>

                                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Run Text="🔗 " FontSize="14" />
                                    <Hyperlink NavigateUri="https://github.com/username/MouseGestures"
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="#7B68AB">
                                        <Run Text="GitHub Repository" />
                                    </Hyperlink>
                                </TextBlock>

                                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Run Text="Copyright © 2026 " Foreground="#666666" />
                                    <Hyperlink NavigateUri="mailto:peter.janak@hotmail.com"
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="#7B68AB">
                                        <Run Text="Peter Janák" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="💾 Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource ModernButtonStyle}"
                    Width="100" />
            <Button Content="✖ Close"
                    Click="CloseButton_Click"
                    Style="{StaticResource ModernButtonStyle}"
                    Width="100" />
        </StackPanel>
    </Grid>
</Window>